# PIONA Studio — Git Attributes
# Text normalization only. No LFS. Binaries → Google Drive (PIONA Assets/).

# Default: auto-detect line endings
* text=auto

# Force LF for all text files committed to repo
*.md text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.cursorrules text eol=lf

# Binary files — no diff, no merge, no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.mp4 binary
*.mov binary
*.avi binary
*.mp3 binary
*.zip binary
*.gz binary
*.glb binary
*.gltf binary
